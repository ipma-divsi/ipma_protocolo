<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_protocolo_form" model="ir.ui.view">
        <field name="name">protocolo.form</field>
        <field name="model">ipma.protocolo</field>
        <field name="arch" type="xml">
            <form string="Protocolo">
                <sheet>
                    <group>
                        <field name="siged"/>
                        <field name="tipo_documento"/>
                        <field name="ambito_geografico"/>
                        <field name="entidades_signatarias"/>
                        <field name="classificacao_entidades"/>
                        <field name="designacao_documento"/>
                        <field name="sigla"/>
                        <field name="ambito_objeto"/>
                        <field name="data_assinatura"/>
                        <field name="entrada_vigor"/>
                        <field name="data_vigencia"/>
                        <field name="periodo_vigencia"/>
                        <field name="antecedencia_revisao_denuncia"/>
                        <field name="obrigacoes_financeiras"/>
                        <field name="valor"/>
                        <field name="ponto_focal_ipma_nome"/>
                        <field name="ponto_focal_ipma_uo"/>
                        <field name="ponto_focal_ipma_tlf"/>
                        <field name="ponto_focal_ipma_email"/>
                        <field name="ponto_focal_parceiros_nome"/>
                        <field name="ponto_focal_parceiros_tlf"/>
                        <field name="ponto_focal_parceiros_email"/>
                        <field name="outros_protocolos_mesmas_entidades"/>
                        <field name="numero_documento_relacionado"/>
                        <field name="ativo"/>
                        <field name="observacoes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_protocolo_tree" model="ir.ui.view">
        <field name="name">protocolo.tree</field>
        <field name="model">ipma.protocolo</field>
        <field name="arch" type="xml">
            <tree string="Protocolos">
                <field name="siged"/>
                <field name="tipo_documento"/>
                <field name="ambito_geografico"/>
                <field name="entidades_signatarias"/>
                <field name="classificacao_entidades"/>
                <field name="designacao_documento"/>
                <field name="sigla"/>
                <field name="ambito_objeto"/>
                <field name="data_assinatura"/>
                <field name="entrada_vigor"/>
                <field name="data_vigencia"/>
                <field name="periodo_vigencia"/>
                <field name="antecedencia_revisao_denuncia"/>
                <field name="obrigacoes_financeiras"/>
                <field name="valor"/>
                <field name="ponto_focal_ipma_nome"/>
                <field name="ponto_focal_ipma_uo"/>
                <field name="ponto_focal_ipma_tlf"/>
                <field name="ponto_focal_ipma_email"/>
                <field name="ponto_focal_parceiros_nome"/>
                <field name="ponto_focal_parceiros_tlf"/>
                <field name="ponto_focal_parceiros_email"/>
                <field name="outros_protocolos_mesmas_entidades"/>
                <field name="numero_documento_relacionado"/>
                <field name="ativo"/>
                <field name="observacoes"/>
            </tree>
        </field>
    </record>
</odoo>