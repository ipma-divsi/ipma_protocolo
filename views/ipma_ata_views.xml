<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ATA ACTIONS -->
    <record id="action_ata" model="ir.actions.act_window">
        <field name="name">Atas</field>
        <field name="res_model">ipma.ata</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Criar a primeira ata
            </p>
        </field>
    </record>

    <!-- ATA TREE VIEW -->
    <record id="view_ata_tree" model="ir.ui.view">
        <field name="name">ipma.ata.tree</field>
        <field name="model">ipma.ata</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="protocolo_id" readonly="1"/>
                <field name="data_assinatura"/>
                <field name="entrada_vigor"/>
            </tree>
        </field>
    </record>

    <!-- ATA FORM VIEW -->
    <record id="view_ata_form" model="ir.ui.view">
        <field name="name">ipma.ata.form</field>
        <field name="model">ipma.ata</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="protocolo_id" readonly="1"/>
                            <field name="data_assinatura"/>
                            <field name="entrada_vigor"/>
                        </group>
                        <group>
                            <field name="data_vigencia"/>
                            <field name="periodo_vigencia"/>
                            <field name="protocolo_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="observacoes" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
