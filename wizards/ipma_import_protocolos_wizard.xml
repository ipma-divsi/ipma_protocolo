<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_ipma_import_protocolos_wizard_form" model="ir.ui.view">
        <field name="name">ipma.import.protocolos.wizard.form</field>
        <field name="model">ipma.import.protocolos.wizard</field>
        <field name="arch" type="xml">
            <form string="Importar Protocolos">
                <sheet>
                    <group>
                        <field name="file" filename="filename"/>
                        <field name="filename" invisible="1"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Importar" type="object" name="action_import" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_ipma_import_protocolos_wizard" model="ir.actions.act_window">
        <field name="name">Importar Protocolos</field>
        <field name="res_model">ipma.import.protocolos.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    
</odoo>
